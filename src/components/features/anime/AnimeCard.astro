---
import Image from "@components/atoms/Image/Image.astro";

interface Props {
	anime: {
		title: string;
		cover: string;
		link: string;
		status: string;
		rating: number;
		personalRating?: number;
		publicRating?: number;
		progress: number;
		totalEpisodes: number;
		description: string;
		year: string;
		studio: string;
		genre: string[];
	};
	statusInfo: {
		text: string;
		class: string;
		icon: string;
	};
	yearLabel: string;
	studioLabel: string;
}

const { anime, statusInfo, yearLabel, studioLabel } = Astro.props;

const progressPercent =
	anime.totalEpisodes > 0 ? (anime.progress / anime.totalEpisodes) * 100 : 0;
const personalRating = Number(anime.personalRating) || 0;
const publicRating = Number(anime.publicRating) || Number(anime.rating) || 0;
const hasPersonalRating = personalRating > 0;
const hasPublicRating = publicRating > 0;
const formatRating = (rating: number) => rating.toFixed(1);
---

<div
	class="group relative bg-(--card-bg) border border-(--line-divider) rounded-(--radius-large) overflow-hidden hover:shadow-lg"
	data-anime-status={anime.status}
>
	<div class="relative anime-cover-container aspect-2/3 overflow-hidden">
		<a
			href={anime.link}
			target="_blank"
			rel="noopener noreferrer"
			class="block w-full h-full"
		>
			<Image
				src={anime.cover}
				alt={anime.title}
				class="w-full h-full object-cover transition-transform duration-200 group-hover:scale-110"
				widths={[200, 400, 600]}
				sizes="(max-width: 640px) 50vw, (max-width: 1024px) 25vw, 20vw"
			/>
			<div
				class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
			>
				<div class="absolute inset-0 flex items-center justify-center">
					<div
						class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center"
					>
						<svg
							class="w-6 h-6 text-gray-800 ml-1"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path d="M8 5v14l11-7z"></path>
						</svg>
					</div>
				</div>
			</div>
		</a>

		<div
			class={`absolute top-2 left-2 px-2 py-1 rounded-md text-xs font-medium ${statusInfo.class}`}
		>
			<span class="mr-1">{statusInfo.icon}</span>
			<span>{statusInfo.text}</span>
		</div>

		{
			(hasPersonalRating || hasPublicRating) && (
				<div class="absolute top-2 right-2 flex flex-col items-end gap-1.5 text-xs font-medium">
					{hasPersonalRating && (
						<div class="flex items-center gap-1.5 rounded-md border border-[var(--line-divider)] bg-[rgba(248,245,241,0.9)] px-2 py-1 text-[var(--ink)] shadow-[0_1px_3px_rgba(37,36,34,0.12)] backdrop-blur-[2px]">
							<span
								class="text-[0.68rem] font-semibold text-[var(--amber-ink)]"
								style="font-family: var(--font-serif);"
							>
								XGN
							</span>
							<span class="tabular-nums">
								{formatRating(personalRating)}
							</span>
						</div>
					)}
					{hasPublicRating && (
						<div class="flex items-center gap-1.5 rounded-md border border-[var(--line-divider)] bg-[rgba(248,245,241,0.94)] px-2 py-1 text-[var(--ink)] shadow-[0_1px_3px_rgba(37,36,34,0.14)] backdrop-blur-[2px]">
							<img
								src="/assets/icons/bangumi.svg"
								alt="Bangumi"
								class="h-3.5 w-3.5 shrink-0"
								loading="lazy"
							/>
							<span class="tabular-nums">
								{formatRating(publicRating)}
							</span>
						</div>
					)}
				</div>
			)
		}

		{
			anime.status === "watching" && (
				<div class="absolute bottom-0 left-0 right-0 bg-linear-to-t from-black/80 to-transparent p-2">
					<div class="w-full bg-white/20 rounded-full h-1.5 mb-1">
						<div
							class="bg-linear-to-r from-emerald-400 to-teal-400 h-1.5 rounded-full transition-all duration-300"
							style={`width: ${progressPercent}%`}
						/>
					</div>
					<div class="text-white text-xs font-medium">
						{anime.progress}/{anime.totalEpisodes} (
						{Math.round(progressPercent)}%)
					</div>
				</div>
			)
		}
	</div>

	<div class="p-3">
		<h3
			class="text-sm font-bold text-black/90 dark:text-white/90 mb-1 leading-tight"
		>
			{anime.title}
		</h3>
		<p
			class="text-black/60 dark:text-white/60 text-xs mb-2 line-clamp-2"
			title={anime.description}
		>
			{anime.description}
		</p>

		<div class="space-y-1 text-xs">
			<div class="flex justify-between items-center">
				<span class="text-black/50 dark:text-white/50 shrink-0">
					{yearLabel}
				</span>
				<span
					class="text-black/70 dark:text-white/70 truncate ml-2 text-right"
				>
					{anime.year}
				</span>
			</div>
			<div class="flex justify-between items-start">
				<span class="text-black/50 dark:text-white/50 shrink-0 mt-0.5">
					{studioLabel}
				</span>
				<span
					class="text-black/70 dark:text-white/70 text-right ml-2 line-clamp-2 wrap-break-word"
					title={anime.studio}
				>
					{anime.studio}
				</span>
			</div>
			<div class="flex flex-wrap gap-1 mt-2">
				{
					anime.genre.map((g) => (
						<span class="px-1.5 py-0.5 bg-(--btn-regular-bg) text-black/70 dark:text-white/70 rounded text-xs">
							{g}
						</span>
					))
				}
			</div>
		</div>
	</div>
</div>
