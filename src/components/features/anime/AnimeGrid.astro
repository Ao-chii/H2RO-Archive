---
import AnimeCard from "./AnimeCard.astro";

interface StatusInfo {
	text: string;
	class: string;
	icon: string;
}

interface AnimeItem {
	title: string;
	cover: string;
	link: string;
	status: string;
	rating: number;
	progress: number;
	totalEpisodes: number;
	description: string;
	year: string;
	studio: string;
	genre: string[];
}

interface Props {
	animeList: AnimeItem[];
	statusMap: Record<string, StatusInfo>;
	yearLabel: string;
	studioLabel: string;
}

const { animeList, statusMap, yearLabel, studioLabel } = Astro.props;
---

<div
	id="anime-list-container"
	class="anime-grid-container grid gap-4 md:gap-6 opacity-0 transition-opacity duration-300"
>
	{
		animeList.map((anime) => {
			const statusInfo = statusMap[anime.status] || {
				text: anime.status,
				class: "btn-regular",
				icon: "?",
			};
			return (
				<AnimeCard
					anime={anime}
					statusInfo={statusInfo}
					yearLabel={yearLabel}
					studioLabel={studioLabel}
				/>
			);
		})
	}
</div>

<div id="anime-pagination-root" class="mt-6"></div>
