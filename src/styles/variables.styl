/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large 0.5rem
  --content-delay 150ms
  --wallpaper-opacity 0.8
  --wallpaper-blur 0px
  --card-transparent-opacity 0.5
  --paper #f4f3ef
  --paper-soft #e6e3dc
  --paper-panel #fffdf8
  --paper-border #e6e3dc
  --paper-border-strong #d8d2c8
  --ink #2c2a29
  --ink-soft #3f3b36
  --muted #77716a
  --amber #e6cdb1
  --amber-ink #6f4a2e
  --sage #d4e0ce
  --sage-ink #40563c
  --red #b86b5d
  --red-ink #9f3a2f
  --blue #6f8ea8
  --blue-ink #315f7d
  --violet #8b7aa8
  --violet-ink #5d4c7d
  --passed-bg rgba(212, 224, 206, 0.55)
  --running-bg rgba(230, 205, 177, 0.48)
  --failed-bg rgba(159, 58, 47, 0.14)
  --tool-bg rgba(49, 95, 125, 0.14)
  --muted-bg rgba(95, 90, 82, 0.12)
  --model-bg rgba(93, 76, 125, 0.13)
  --grid-line rgba(37, 36, 34, 0.055)
  --font-ui "Marcellus", "PingFang SC", "Hiragino Sans GB", "Noto Sans SC", "Microsoft YaHei", sans-serif
  --font-reading "EB Garamond", "LXGW WenKai", "Noto Serif SC", "Songti SC", "STSong", "SimSun", serif
  --font-code var(--font-jetbrains-mono), "JetBrains Mono", SFMono-Regular, Consolas, monospace

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  --primary: #6f4a2e #6f4a2e
  --page-bg: var(--paper) var(--paper)
  --card-bg: var(--paper-panel) var(--paper-panel)
  --card-bg-transparent: rgba(255, 255, 255, 0.8) rgba(23, 23, 23, 0.8)

  --btn-content: #6f4a2e #6f4a2e

  --btn-regular-bg: rgba(230, 205, 177, 0.48) rgba(230, 205, 177, 0.48)
  --btn-regular-bg-hover: rgba(230, 205, 177, 0.65) rgba(230, 205, 177, 0.65)
  --btn-regular-bg-active: rgba(230, 205, 177, 0.82) rgba(230, 205, 177, 0.82)

  --btn-plain-bg-hover: rgba(230, 205, 177, 0.32) rgba(230, 205, 177, 0.32)
  --btn-plain-bg-active: rgba(230, 205, 177, 0.48) rgba(230, 205, 177, 0.48)

  --btn-card-bg-hover: #fbfaf7 #fbfaf7
  --btn-card-bg-active: var(--paper-soft) var(--paper-soft)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: var(--ink)

  --title-active: #6f4a2e

  --line-divider: rgba(44, 42, 41, 0.10) rgba(44, 42, 41, 0.10)

  --line-color: rgba(44, 42, 41, 0.12) rgba(44, 42, 41, 0.12)
  --meta-divider: rgba(44, 42, 41, 0.24) rgba(44, 42, 41, 0.24)
  --content-meta: rgba(44, 42, 41, 0.72) rgba(44, 42, 41, 0.72)

  --inline-code-bg: rgba(44, 42, 41, 0.075) rgba(44, 42, 41, 0.075)
  --inline-code-color: var(--ink-soft) var(--ink-soft)
  --selection-bg: oklch(0.90 0.05 var(--hue)) oklch(0.40 0.08 var(--hue))
  --codeblock-selection: var(--selection-bg)
  --codeblock-bg: #eeece6 #eeece6
  --codeblock-topbar-bg: #ded8ce #ded8ce

  --license-block-bg: black(0.03) var(--codeblock-bg)

  --link-color: var(--blue-ink) var(--blue-ink)
  --link-underline: rgba(49, 95, 125, 0.28) rgba(49, 95, 125, 0.28)
  --link-hover: rgba(49, 95, 125, 0.62) rgba(49, 95, 125, 0.62)
  --link-active: oklch(0.90 0.05 var(--hue)) oklch(0.35 0.07 var(--hue))

  --float-panel-bg: var(--paper-panel) var(--paper-panel)

  --scrollbar-bg-light: black(0.4)
  --scrollbar-bg-hover-light: black(0.5)
  --scrollbar-bg-active-light: black(0.6)

  --scrollbar-bg-dark: white(0.4)
  --scrollbar-bg-hover-dark: white(0.5)
  --scrollbar-bg-active-dark: white(0.6)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --color-selection-bar: rainbow-light rainbow-dark

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: var(--sage-ink) var(--sage-ink)
  --admonitions-color-note: var(--blue-ink) var(--blue-ink)
  --admonitions-color-important: var(--violet-ink) var(--violet-ink)
  --admonitions-color-warning: var(--amber-ink) var(--amber-ink)
  --admonitions-color-caution: var(--red-ink) var(--red-ink)

  --toc-badge-bg: oklch(0.9 0.045 var(--hue)) var(--btn-regular-bg)
  --toc-btn-hover: oklch(0.92 0.015 var(--hue)) oklch(0.22 0.02 var(--hue))
  --toc-btn-active: oklch(0.90 0.015 var(--hue)) oklch(0.25 0.02 var(--hue))
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.70 0.13 var(--hue)) oklch(0.35 0.07 var(--hue))
})

/* 非全屏壁纸模式下，--card-bg-transparent 应该和 --card-bg 一致（不透明） */
body:not(.wallpaper-transparent)
  --card-bg-transparent: var(--card-bg)

body.wallpaper-transparent
  --card-bg-transparent: unquote("rgba(255, 255, 255, var(--card-transparent-opacity, 0.8))")

:root.dark body.wallpaper-transparent
  --card-bg-transparent: unquote("rgba(23, 23, 23, var(--card-transparent-opacity, 0.8))")
